{
  "name": "vigil",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node scripts/strip-ts-nocheck.mjs && prisma db push --accept-data-loss --skip-generate && next build",
