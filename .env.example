# --- Required ---
# Postgres connection string. Use Neon (neon.tech) free tier — no credit card needed.
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Random 32+ character string. Generate one: openssl rand -base64 32
AUTH_SECRET="change-me-to-something-random-at-least-32-chars"

# Public URL of your deployment. On Vercel, Vercel sets VERCEL_URL automatically;
# keep this for links inside phishing emails and SCORM packages.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# --- Optional (POC can skip all of these) ---

# LLM for AI Composer (Groq is free)
LLM_PROVIDER=""
LLM_API_KEY=""
LLM_MODEL="llama-3.3-70b-versatile"
LLM_BASE_URL="https://api.groq.com/openai/v1"

# Email sending (Resend free tier: 3k emails/month)
EMAIL_PROVIDER=""
RESEND_API_KEY=""
EMAIL_FROM="Vigil Alerts <alerts@yourdomain.com>"

# Vishing (Twilio trial includes $15 credit)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Realistic TTS (optional)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
